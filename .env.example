# Unpissed v0.4
# Static app uses js/config.js in the browser.
# Do not put Supabase service_role keys in frontend files.

# For Netlify/Vite later, if we convert to a build step:
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY
VITE_SUPABASE_STORAGE_BUCKET=bathroom-photos

# Future server-only variables, only for Netlify Functions:
SUPABASE_SERVICE_ROLE_KEY=
